# Required server configuration (deployment fails fast when missing or empty)
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_SERVICE_KEY=replace-with-server-only-service-role-key
BRAIN_ACCESS_PASSWORD=replace-with-a-strong-login-password
BRAIN_SESSION_SECRET=replace-with-at-least-32-random-characters

# Distinct scoped bearer credentials; never put these in URLs or browser bundles
BRAIN_API_READ_KEY=replace-with-at-least-32-random-characters-read
BRAIN_SYNC_WRITE_KEY=replace-with-at-least-32-random-characters-sync
BRAIN_MEMORY_WRITE_KEY=replace-with-at-least-32-random-characters-memory

# Optional knowledge sources
SUPERMEMORY_API_KEY=
MEM0_API_URL=
OBSIDIAN_API_URL=
OBSIDIAN_API_KEY=
